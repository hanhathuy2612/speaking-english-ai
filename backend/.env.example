# Copy to .env. Loads .env, then .env.$APP_ENV (default development), then .env.local — later overrides. Restart after changes.
# Variable names match app/core/config.py (Pydantic Settings).

OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_API_KEY=lm-studio
OPENAI_MODEL=qwen2.5-7b-instruct
# Optional: answer-tips /guidance only. Empty = same as OPENAI_MODEL.
# OPENAI_GUIDANCE_MODEL=qwen2.5-7b-instruct
#
# Backward-compatible aliases still work:
# LMSTUDIO_BASE_URL / LMSTUDIO_API_KEY / LMSTUDIO_MODEL / LMSTUDIO_GUIDANCE_MODEL

JWT_SECRET_KEY=super-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/speaking_english

# Capacitor app + `cap:sync:android:dev:emu` (live reload Origin = http://10.0.2.2:4200).
CORS_ALLOWED_ORIGINS=["http://localhost:4200", "http://192.168.1.44:4200", "http://10.0.2.2:4200", "http://localhost", "https://localhost", "capacitor://localhost", "ionic://localhost"]

MAX_AUDIO_UPLOAD_MB=10
REQUEST_TIMEOUT_SECONDS=60

# ─── LM / conversation (defaults = config.py) ─────────────────────────────────
LM_CONVERSATION_MAX_TOKENS=256
# LM_SYSTEM_PROMPT_EXTRA=

# After STT: optional LLM “cleanup”. false = raw STT only (recommended). true = strict similarity checks apply.
LM_NORMALIZE_TRANSCRIPT=false
LM_NORMALIZE_TEMPERATURE=0.05
LM_NORMALIZE_MAX_TOKENS=200
LM_NORMALIZE_INCLUDE_TOPIC_CONTEXT=false
LM_NORMALIZE_MIN_SIMILARITY=0.65

# ─── STT (faster-whisper) ───────────────────────────────────────────────────
STT_MODEL_SIZE=small
STT_BEAM_SIZE=5
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8

# ─── TTS (edge-tts) ───────────────────────────────────────────────────────────
TTS_RATE=+0%
TTS_VOICE=en-US-JennyNeural

# ─── Optional paths ─────────────────────────────────────────────────────────
# FFMPEG_PATH=

# Comma-separated emails (registered users) granted role "admin" on each app startup
# Use a domain with a dot (EmailStr); not admin@localhost
BOOTSTRAP_ADMIN_EMAILS=admin@example.com

# Optional: only used when running `alembic upgrade` for revision seed_admin_user
# ALEMBIC_ADMIN_EMAIL=admin@example.com
# ALEMBIC_ADMIN_USERNAME=admin
# ALEMBIC_ADMIN_PASSWORD=your-secure-password

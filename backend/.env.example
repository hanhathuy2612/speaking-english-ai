# Copy this file to .env and fill in the values.

# ── LM Studio (OpenAI-compatible local LLM) ─────────────────────────────────────
# Start LM Studio, load a model, then enable Local Server (port 1234 by default).
LMSTUDIO_BASE_URL=http://localhost:1234
# Leave blank – LM Studio local server does not require a key.
LMSTUDIO_API_KEY=
# Model to use (must be loaded in LM Studio). Recommended: llama-3.2-3b-instruct (Q4_K_M).
# Leave blank to use whatever model is currently loaded.
LMSTUDIO_MODEL=llama-3.2-3b-instruct@q4_k_m
# Max tokens per AI reply. Default 256 for natural length.
# LM_CONVERSATION_MAX_TOKENS=256
# Optional: extra instruction for tone (e.g. "Use simple words. Sound like texting a friend.")
# LM_SYSTEM_PROMPT_EXTRA=

# ── TTS (edge-tts) ───────────────────────────────────────────────────────────
# Speech rate: +0% = default, -20% = slower, +20% = faster.
# TTS_RATE=+0%
# Voice (e.g. en-US-JennyNeural, en-GB-SoniaNeural).
# TTS_VOICE=en-US-JennyNeural

# ── Auth / JWT ─────────────────────────────────────────────────────────────────
# Change this to a long random string in production.
JWT_SECRET_KEY=super-secret-change-me

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite path (relative to where you run uvicorn).
DATABASE_URL=sqlite+aiosqlite:///./speaking_english.db

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated if you need multiple origins.
CORS_ALLOWED_ORIGINS=["http://localhost:4200"]

# ── FFmpeg (optional) ─────────────────────────────────────────────────────────
# If ffmpeg is not on PATH (e.g. after winget install), set full path to ffmpeg.exe.
# FFMPEG_PATH=C:\Users\...\ffmpeg-8.0.1-full_build\bin\ffmpeg.exe

# ── Limits ────────────────────────────────────────────────────────────────────
# Max size in MB for uploaded audio in the WebSocket conversation.
MAX_AUDIO_UPLOAD_MB=10
# Request timeout in seconds.
REQUEST_TIMEOUT_SECONDS=60

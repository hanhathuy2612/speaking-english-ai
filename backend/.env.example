# Copy to .env. Loads .env, then .env.$APP_ENV (default development), then .env.local — later overrides. Restart after changes.
# Keep in sync with .env.example and app/core/config.py.

LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=qwen2.5-7b-instruct
# Admin learning-pack AI draft (large JSON). Falls back to LMSTUDIO_MODEL if unset.
# 14B is often slower; use 7B here for faster drafts, or load a quantized GGUF in LM Studio.
# LMSTUDIO_LEARNING_PACK_MODEL=qwen2.5-14b-instruct-1m
LMSTUDIO_LEARNING_PACK_MODEL=qwen2.5-7b-instruct
# Lower = smaller cap, often finishes sooner (raise if JSON is cut off).
LM_LEARNING_PACK_MAX_TOKENS=3000
LM_LEARNING_PACK_TEMPERATURE=0.35
# Bump if 14B times out (local inference can exceed 120s on long JSON).
# REQUEST_TIMEOUT_SECONDS=300

JWT_SECRET_KEY=super-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/speaking_english

# Capacitor: packaged app + live reload from emulator (ng serve at 10.0.2.2:4200).
CORS_ALLOWED_ORIGINS=["http://localhost:4200", "http://192.168.1.44:4200", "http://10.0.2.2:4200", "http://localhost", "https://localhost", "capacitor://localhost", "ionic://localhost"]

MAX_AUDIO_UPLOAD_MB=10
# LLM HTTP read timeout (long user messages / slow local models).
REQUEST_TIMEOUT_SECONDS=120
# Close WS if no frame from client for this long (typing in textarea is kept alive by client ping).
WEBSOCKET_IDLE_TIMEOUT_SECONDS=1800

# LM / conversation — aligned with config.py defaults
LM_CONVERSATION_MAX_TOKENS=256
# LM_SYSTEM_PROMPT_EXTRA=

# After STT: false = raw STT only. true = optional LLM cleanup (use with LM_NORMALIZE_MIN_SIMILARITY).
LM_NORMALIZE_TRANSCRIPT=false
LM_NORMALIZE_TEMPERATURE=0.05
LM_NORMALIZE_MAX_TOKENS=200
LM_NORMALIZE_INCLUDE_TOPIC_CONTEXT=false
LM_NORMALIZE_MIN_SIMILARITY=0.65

STT_MODEL_SIZE=small
STT_BEAM_SIZE=5
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8

TTS_RATE=+0%
TTS_VOICE=en-US-JennyNeural
# FFMPEG_PATH=
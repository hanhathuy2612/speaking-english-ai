# Copy this file to .env and fill in the values

# LM Studio – start LM Studio, load a model, then enable Local Server (port 1234 by default)
LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_API_KEY=           # leave blank – LM Studio local server doesn't require a key
LMSTUDIO_MODEL=             # leave blank to use whatever model is currently loaded

# Auth / JWT  – change this to a long random string in production
JWT_SECRET_KEY=super-secret-change-me

# SQLite database path (relative to where you run uvicorn)
DATABASE_URL=sqlite+aiosqlite:///./speaking_english.db

# Allowed origins for CORS (comma-separated if you need multiple)
CORS_ALLOWED_ORIGINS=["http://localhost:4200"]

# Limits
MAX_AUDIO_UPLOAD_MB=10
REQUEST_TIMEOUT_SECONDS=60

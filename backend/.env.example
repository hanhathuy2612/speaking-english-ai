# Copy to .env. Loads .env, then .env.$APP_ENV (default development), then .env.local — later overrides. Restart after changes.

LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_API_KEY=
LMSTUDIO_MODEL=llama-3.2-3b-instruct

JWT_SECRET_KEY=super-secret-change-me

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/speaking_english

# Capacitor app + `cap:sync:android:dev:emu` (live reload Origin = http://10.0.2.2:4200).
CORS_ALLOWED_ORIGINS=["http://localhost:4200", "http://192.168.1.44:4200", "http://10.0.2.2:4200", "http://localhost", "https://localhost", "capacitor://localhost", "ionic://localhost"]

MAX_AUDIO_UPLOAD_MB=10
REQUEST_TIMEOUT_SECONDS=60

# Optional (defaults in app/core/config.py): LM_CONVERSATION_MAX_TOKENS, LM_SYSTEM_PROMPT_EXTRA,
# LM_NORMALIZE_TRANSCRIPT=true, LM_NORMALIZE_TEMPERATURE=0.15, LM_NORMALIZE_MAX_TOKENS=400,
# LM_NORMALIZE_INCLUDE_TOPIC_CONTEXT=false, LM_NORMALIZE_MIN_SIMILARITY=0.38,
# TTS_RATE, TTS_VOICE, STT_MODEL_SIZE, STT_BEAM_SIZE, STT_DEVICE, STT_COMPUTE_TYPE, FFMPEG_PATH

# Comma-separated emails (registered users) granted role "admin" on each app startup
# Use a domain with a dot (EmailStr); not admin@localhost
BOOTSTRAP_ADMIN_EMAILS=admin@example.com

# Optional: only used when running `alembic upgrade` for revision seed_admin_user
# ALEMBIC_ADMIN_EMAIL=admin@example.com
# ALEMBIC_ADMIN_USERNAME=admin
# ALEMBIC_ADMIN_PASSWORD=your-secure-password
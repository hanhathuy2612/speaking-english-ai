{
  "name": "speakai",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0",
    "start:android:emu": "ng serve --host 0.0.0.0 --configuration=android-emulator",
    "build": "ng build",
    "build:mobile": "ng build --configuration=mobile",
    "cap:sync": "cap sync android",
    "cap:sync:android:dev:emu": "cross-env CAPACITOR_DEV_SERVER_URL=http://10.0.2.2:4200 cap sync android",
    "cap:run:android:dev:emu": "cap run android -l --host=10.0.2.2 --port=4200 --no-sync",
    "cap:open": "cap open android",
    "android:build": "npm run build:mobile && npm run cap:sync",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.7.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/localize": "^21.2.4",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@capacitor/android": "^7.6.0",
    "@capacitor/cli": "^7.6.0",
    "@capacitor/core": "^7.6.0",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@ng-select/ng-select": "^21.5.2",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "ngx-bootstrap": "^21.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@types/node": "^22.10.0",
    "cross-env": "^7.0.3",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
